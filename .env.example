# Single-key setup:
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: rotate across multiple keys to bypass per-key 15 RPM limits.
# When set, GOOGLE_API_KEYS takes precedence over GOOGLE_API_KEY. The pipeline
# round-robins across these keys and falls over to the next on a 429.
# GOOGLE_API_KEYS=key1,key2,key3

OPENAI_API_KEY=your_openai_api_key_here

# ─── API security (all optional — defaults are local-first) ────────────
# Bearer token required for POST /tasks/run when set. Leave unset for
# laptop-only use; set for any non-localhost deployment. Example:
#   AGENTXAI_API_TOKEN=$(openssl rand -hex 32)
# AGENTXAI_API_TOKEN=

# Comma-separated CORS allow-list. Defaults to localhost:{8501,8000,3000}
# and 127.0.0.1 equivalents when unset.
# AGENTXAI_CORS_ORIGINS=https://your-dashboard.example.com

# Emergency override: restore the historical wildcard CORS. Prefer the
# explicit allow-list above unless you genuinely need any-origin access.
# AGENTXAI_ALLOW_CORS_ALL=false

# Where the Streamlit dashboard looks for the API.
# AGENTXAI_API_URL=http://localhost:8000
