# Single-key setup:
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: rotate across multiple keys to bypass per-key 15 RPM limits.
# When set, GOOGLE_API_KEYS takes precedence over GOOGLE_API_KEY. The pipeline
# round-robins across these keys and falls over to the next on a 429.
# GOOGLE_API_KEYS=key1,key2,key3

OPENAI_API_KEY=your_openai_api_key_here
